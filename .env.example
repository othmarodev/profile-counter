# ─────────────────────────────────────────────────────────────────────────────
#  profile-counter — environment variables
# ─────────────────────────────────────────────────────────────────────────────
#  Get these from your Upstash Redis dashboard:
#    https://console.upstash.com → click your database → "REST API" tab
#
#  Free tier (10,000 commands/day) is more than enough for ~5,000 daily visits.
# ─────────────────────────────────────────────────────────────────────────────

UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here
